# ═══════════════════════════════════════════════════════════════════════════════
# Phoenix Mesh Configuration - Complete Guide
# Copy this file to .env and update values as needed
# ═══════════════════════════════════════════════════════════════════════════════

# ─── OLLAMA LLM Configuration ───────────────────────────────────────────────────
# Ollama provides local, self-hosted LLM for Root Cause Analysis (RCA)
# Setup: docker-compose up -d ollama
# Then: docker exec phoenix-ollama ollama pull mistral
# Models: mistral, neural-chat, llama2, zephyr, orca2

OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT_MS=60000

# ─── RCA (Root Cause Analysis) Configuration ────────────────────────────────────
# Options: 
#   - ollama (local, free, offline)
#   - rules (deterministic fallback, always available)


RCA_PROVIDER=ollama
RCA_CACHE_TTL_MS=600000

# ─── Controller Configuration ───────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info
NODE_ENV=development

# For in-cluster Kubernetes, set to 'true'. For local dev, use default ~/.kube/config
K8S_IN_CLUSTER=false
KUBECONFIG=

# ─── Observability & Metrics ────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION=15d

# ─── Notifications (Optional) ───────────────────────────────────────────────────
# Leave empty to disable Slack notifications
SLACK_WEBHOOK_URL=

# ─── Sidecar Health Check Configuration ─────────────────────────────────────────
PROBE_INTERVAL_MS=5000           # Check service health every 5 seconds
FAIL_THRESHOLD=3                 # Report failure after 3 consecutive failures
PROBE_TIMEOUT_MS=2000            # Timeout per health check request

# ─── Recovery & Remediation ────────────────────────────────────────────────────
RECOVERY_WINDOW_MS=60000         # Wait 60s for auto-recovery before rollback
ERROR_RATE_THRESHOLD=0.01        # 1% error rate threshold for healthy status

# ─── Service Ports ──────────────────────────────────────────────────────────────
ORDER_SERVICE_PORT=3000
PAYMENT_SERVICE_PORT=3000
INVENTORY_SERVICE_PORT=3000
