# ────────────────────────────────────────────────────────────────────────────
# Phoenix Mesh — Environment Configuration Example
# Copy this file to .env and fill in your values.
# ────────────────────────────────────────────────────────────────────────────

# ── Ollama (Self-hosted LLM for RCA) ─────────────────────────────────────────
# URL of the Ollama container (default matches docker-compose service name)
OLLAMA_URL=http://ollama:11434

# LLM model to use for Root Cause Analysis (must be pulled into Ollama first)
# Supported: mistral, llama2, neural-chat, codellama
OLLAMA_MODEL=mistral

# Timeout in milliseconds for Ollama inference requests
OLLAMA_TIMEOUT_MS=60000

# ── Phoenix Controller ────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info
NODE_ENV=development

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://phoenix-prometheus:9090

# ── Slack Notifications (optional) ───────────────────────────────────────────
# Leave blank to disable Slack alerts
PHOENIX_SLACK_WEBHOOK_URL=

# ── Phoenix Sidecar Agent ─────────────────────────────────────────────────────
# How often the sidecar probes the upstream service (milliseconds)
PROBE_INTERVAL_MS=5000

# Number of consecutive failures before alerting the controller
FAIL_THRESHOLD=3

# Timeout per health probe request (milliseconds)
PROBE_TIMEOUT_MS=2000

# ── Incident Recovery ─────────────────────────────────────────────────────────
# Time window to wait for auto-recovery before triggering rollback (milliseconds)
RECOVERY_WINDOW_MS=60000

# Error rate threshold below which a service is considered recovered (errors/sec)
ERROR_RATE_THRESHOLD=0.01

# ── RCA Cache ─────────────────────────────────────────────────────────────────
# Duration in milliseconds to cache RCA results for the same incident pattern
RCA_CACHE_TTL_MS=300000
